  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "outDir": "./dist",
    "rootDir": "./",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "generated/**/*"]
}
